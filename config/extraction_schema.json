{
  "project_type": "railway_system_enterprise",
  "description": "针对铁路系统企业的邮件实体提取配置",
  "version": "1.0",
  
  "extraction_fields": [
    {
      "name": "company",
      "type": "string",
      "required": true,
      "description": "客户公司名称（如某铁路局、工程公司等）"
    },
    {
      "name": "company_type",
      "type": "string",
      "required": false,
      "enum": ["铁路局", "工程公司", "设备供应商", "技术服务商", "其他"],
      "description": "公司在铁路系统中的角色类型"
    },
    {
      "name": "contact",
      "type": "array",
      "required": false,
      "description": "外部对接人（包括职位、部门）",
      "item_schema": {
        "name": "string",
        "role": "string",
        "department": "string",
        "email": "string"
      }
    },
    {
      "name": "project",
      "type": "array",
      "required": false,
      "description": "项目名称、代号或工程代码",
      "item_schema": {
        "name": "string",
        "code": "string",
        "category": "string"
      }
    },
    {
      "name": "project_category",
      "type": "string",
      "required": false,
      "enum": ["基础设施建设", "信息系统", "设备采购", "技术改造", "安全改进", "运维服务", "其他"],
      "description": "项目类型（铁路系统特有分类）"
    },
    {
      "name": "internal_owner",
      "type": "array",
      "required": false,
      "description": "内部项目负责人（如项目经理、部门经理）",
      "item_schema": {
        "name": "string",
        "role": "string",
        "department": "string"
      }
    },
    {
      "name": "contract_amount",
      "type": "number",
      "required": false,
      "description": "合同/项目金额（万元）"
    },
    {
      "name": "key_dates",
      "type": "array",
      "required": false,
      "description": "关键时间节点",
      "item_schema": {
        "date": "string (YYYY-MM-DD)",
        "event": "string (如：投标截止、开工、交付、验收等)"
      }
    },
    {
      "name": "project_status_detail",
      "type": "object",
      "required": false,
      "description": "项目执行状态详情",
      "properties": {
        "stage": {
          "type": "string",
          "enum": ["需求分析", "方案设计", "采购/招标", "实施/建设", "测试/验收", "交付", "运维", "已完成", "暂停", "取消"],
          "description": "项目当前阶段"
        },
        "progress_percentage": {
          "type": "integer",
          "min": 0,
          "max": 100,
          "description": "完成度百分比"
        },
        "health": {
          "type": "string",
          "enum": ["绿", "黄", "红"],
          "description": "项目健康度（绿=正常，黄=预警，红=风险）"
        }
      }
    },
    {
      "name": "procurement_status",
      "type": "string",
      "required": false,
      "enum": ["未启动", "已发布", "招标中", "评标中", "待签约", "已签约", "采购中", "已收货", "已验收", "已支付"],
      "description": "采购/招标状态（铁路系统特有）"
    },
    {
      "name": "risks",
      "type": "array",
      "required": false,
      "description": "项目风险、问题或延期风险",
      "item_schema": {
        "type": "string",
        "description": "string (如：需求变更、供应链延期、资金缺口、技术难点等)"
      }
    },
    {
      "name": "compliance_requirements",
      "type": "array",
      "required": false,
      "description": "合规/安全/标准要求（铁路系统特有）",
      "item_schema": {
        "type": "string",
        "description": "string (如：铁路总公司标准、GB标准、安全认证等)"
      }
    },
    {
      "name": "customer_sentiment",
      "type": "string",
      "required": false,
      "enum": ["满意", "中立", "不满意", "有风险"],
      "description": "客户满意度/关系状态"
    },
    {
      "name": "next_action",
      "type": "array",
      "required": false,
      "description": "后续行动和负责人",
      "item_schema": {
        "action": "string",
        "owner": "string",
        "deadline": "string (YYYY-MM-DD)"
      }
    },
    {
      "name": "summary",
      "type": "string",
      "required": true,
      "description": "邮件核心内容摘要（<200字）"
    }
  ],

  "graph_relations": [
    {
      "name": "BELONGS_TO",
      "from": "Contact",
      "to": "Company",
      "description": "外部对接人属于某公司"
    },
    {
      "name": "WORKS_FOR",
      "from": "Employee",
      "to": "Company",
      "description": "内部员工所属部门/公司"
    },
    {
      "name": "PARTICIPATES_IN",
      "from": "Contact",
      "to": "Project",
      "description": "外部对接人参与某项目"
    },
    {
      "name": "MANAGES",
      "from": "Employee",
      "to": "Project",
      "description": "内部负责人管理某项目"
    },
    {
      "name": "CONTACTS",
      "from": "Employee",
      "to": "Contact",
      "description": "内部员工与外部对接人的联系"
    },
    {
      "name": "FOR",
      "from": "Project",
      "to": "Company",
      "description": "项目为客户公司服务"
    },
    {
      "name": "MENTIONS",
      "from": "Email",
      "to": "Project",
      "description": "邮件提及某项目"
    },
    {
      "name": "BETWEEN",
      "from": "Email",
      "to": "Contact",
      "description": "邮件往来的外部对接人"
    },
    {
      "name": "BETWEEN",
      "from": "Email",
      "to": "Employee",
      "description": "邮件往来的内部员工"
    },
    {
      "name": "INVOLVES_COMPANY",
      "from": "Project",
      "to": "Company",
      "description": "项目涉及的上下游企业关系（多方协作）"
    },
    {
      "name": "DEPENDS_ON",
      "from": "Project",
      "to": "Project",
      "description": "项目间的依赖关系"
    }
  ],

  "graph_nodes": [
    {
      "label": "Company",
      "properties": {
        "name": "string (required)",
        "type": "string (铁路局|工程公司|供应商|其他)",
        "aliases": "array[string]",
        "industry": "string",
        "contact_email": "string",
        "contact_phone": "string"
      }
    },
    {
      "label": "Contact",
      "properties": {
        "name": "string (required)",
        "email": "string",
        "role": "string",
        "department": "string",
        "company": "string (reference to Company.name)"
      }
    },
    {
      "label": "Employee",
      "properties": {
        "name": "string (required)",
        "email": "string",
        "role": "string",
        "department": "string"
      }
    },
    {
      "label": "Project",
      "properties": {
        "name": "string (required)",
        "code": "string",
        "category": "string (基础设施|信息系统|采购|技术改造|安全改进|运维|其他)",
        "status": "string (需求|设计|采购|实施|测试|交付|运维|完成|暂停|取消)",
        "progress": "integer (0-100)",
        "health": "string (绿|黄|红)",
        "contract_amount": "number",
        "start_date": "string (YYYY-MM-DD)",
        "expected_end_date": "string (YYYY-MM-DD)",
        "actual_end_date": "string (YYYY-MM-DD)",
        "procurement_status": "string",
        "compliance_requirements": "array[string]",
        "risks": "array[string]",
        "summary": "string"
      }
    },
    {
      "label": "Email",
      "properties": {
        "message_id": "string (required, unique)",
        "subject": "string",
        "from": "string",
        "to": "array[string]",
        "date": "string (YYYY-MM-DD HH:mm:ss)",
        "summary": "string",
        "has_attachment": "boolean"
      }
    }
  ],

  "ai_extraction_prompt_template": "你是一个专业的企业邮件信息提取专家。你需要从下面的邮件内容中，按照 JSON 格式精确提取以下信息：\n\n【提取规则】\n1. company: 如果邮件涉及客户公司，提取其完整名称。如果是铁路相关企业（铁路局、工程公司等），标注其类型。\n2. contact: 提取邮件中的外部对接人（通常是发件人、收件人或正文中提到的人）。包括姓名、职位、所属部门。\n3. project: 提取项目名称、代号或工程编码。并归类为：基础设施建设、信息系统、设备采购、技术改造、安全改进、运维服务等。\n4. internal_owner: 提取我方内部负责人。\n5. contract_amount: 如果邮件中提到金额、合同价格、预算等，以万元为单位提取。\n6. key_dates: 提取所有关键时间节点（投标截止、开工日期、交付日期、验收日期等）。格式：YYYY-MM-DD\n7. project_status_detail: 根据邮件内容推断项目所处阶段（需求|设计|采购|实施|测试|交付|运维|完成|暂停|取消），完成度百分比，以及健康度（绿|黄|红）。\n8. procurement_status: 如果涉及采购/招标，标注状态（未启动|已发布|招标中|评标中|待签约|已签约|采购中|已收货|已验收|已支付）。\n9. risks: 提取邮件中提到的任何风险、问题、延期、技术难点等。\n10. compliance_requirements: 如果提到铁路总公司标准、GB标准、安全认证、合规要求等，提取列出。\n11. customer_sentiment: 根据邮件语气判断客户关系状态（满意|中立|不满意|有风险）。\n12. next_action: 提取邮件中显式或隐含的后续行动项、负责人和截止时间。\n13. summary: 用简洁语言总结邮件要点（<200字）。\n\n【邮件内容】\n{email_content}\n\n【输出格式】\n返回严格的 JSON 对象，字段都是小写英文，如果某字段无信息则返回 null。不要返回任何其他文本，只返回 JSON。",

  "token_optimization": {
    "enabled": true,
    "rules": [
      {
        "name": "noise_email_filter",
        "description": "过滤掉明显的噪音邮件（订阅、系统通知、自动回复等）",
        "patterns": ["OOO", "自动回复", "订阅", "通知", "系统消息", "邮件列表"]
      },
      {
        "name": "text_truncation",
        "description": "长邮件文本截断策略",
        "max_length": 8000,
        "keep_sections": ["开头500字", "中间关键段落", "结尾500字"]
      },
      {
        "name": "reply_history_cleanup",
        "description": "移除邮件回复历史",
        "pattern": "-----Original Message-----"
      },
      {
        "name": "html_stripping",
        "description": "剥离 HTML 标签和样式"
      },
      {
        "name": "signature_removal",
        "description": "移除邮件签名（通常在最后，含图片、公司信息等）"
      }
    ]
  },

  "ragflow_integration": {
    "enabled": true,
    "document_types": [
      {
        "extension": ".pdf",
        "parser": "pdf_parser",
        "preserve": "table_structure"
      },
      {
        "extension": ".docx",
        "parser": "docx_parser"
      },
      {
        "extension": ".xlsx",
        "parser": "excel_parser",
        "preserve": "table_structure_and_formulas"
      },
      {
        "extension": ".xls",
        "parser": "excel_parser",
        "preserve": "table_structure"
      },
      {
        "extension": ".txt",
        "parser": "text_parser"
      },
      {
        "extension": ".zip",
        "parser": "zip_extractor",
        "recursive": true
      }
    ],
    "skip_extensions": [".exe", ".dll", ".png", ".jpg", ".gif", ".ico"]
  },

  "imap_config": {
    "supported_mailboxes": [
      {
        "name": "QQ邮箱",
        "server": "imap.qq.com",
        "port": 993,
        "auth_method": "authorization_code",
        "guide": "https://service.mail.qq.com/cgi-bin/help?subtype=1&&id=28&&no=1001256"
      },
      {
        "name": "Gmail",
        "server": "imap.gmail.com",
        "port": 993,
        "auth_method": "app_password",
        "guide": "https://support.google.com/accounts/answer/185833"
      },
      {
        "name": "阿里企业邮箱",
        "server": "imap.mxhichina.com",
        "port": 993,
        "auth_method": "password_or_auth_code",
        "guide": "https://help.aliyun.com/document_detail/260921.html"
      }
    ],
    "batch_strategy": {
      "time_slice": "monthly",
      "retry_policy": {
        "max_retries": 3,
        "exponential_backoff": true,
        "initial_delay_seconds": 1
      },
      "rate_limiting": {
        "delay_between_fetches_seconds": [0.5, 2.0],
        "type": "random"
      }
    }
  }
}
