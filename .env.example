# ========== OpenAI API Configuration ==========
# 使用阿里云百炼 MaaS 的 OpenAI 兼容接口
# 格式：https://<instance-id>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=qwen-plus
OPENAI_REVIEW_MODEL=qwen-plus
MODEL_REASONING_EFFORT=xhigh

# ========== IMAP Email Configuration ==========
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ========== Redis Configuration ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=mailgraph2024

# ========== Neo4j Configuration ==========
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mailgraph2024

# ========== Milvus Configuration ==========
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=mailgraph_lightrag

# ========== LightRAG Embedding Configuration ==========
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ========== Application Configuration ==========
DATA_DIR=./data
LOG_LEVEL=INFO
